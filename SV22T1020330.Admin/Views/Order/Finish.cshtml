@model SV22T1020330.Models.Sales.OrderViewInfo
@{
    ViewBag.Title = "Hoàn tất đơn hàng";
}

<div class="modal-header text-bg-success">
    <strong class="modal-title">
        Hoàn tất đơn hàng #@Model.OrderID
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form method="post" action="~/Order/Finish/@Model.OrderID">
    <div class="modal-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary()
            </div>
        }
        
        <div class="alert alert-success d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có chắc chắn đơn hàng này đã được giao thành công?
        </div>
        
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Khách hàng</label>
                <input type="text" class="form-control" value="@Model.CustomerName" readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label">Người giao hàng</label>
                <input type="text" class="form-control" value="@Model.ShipperName" readonly />
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-circle"></i> Hoàn tất
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
