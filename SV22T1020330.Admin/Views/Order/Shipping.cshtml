@model SV22T1020330.Models.Sales.OrderViewInfo
@{
    ViewBag.Title = "Chuyển giao hàng";
}

<div class="modal-header text-bg-info">
    <strong class="modal-title">
        Chuyển giao đơn hàng #@Model.OrderID
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form method="post" action="~/Order/Shipping/@Model.OrderID">
    <div class="modal-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary()
            </div>
        }
        
        <div class="alert alert-info d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Chọn người giao hàng để chuyển giao đơn hàng này
        </div>
        
        <div class="row mb-3">
            <div class="col-12">
                <label class="form-label">Khách hàng</label>
                <input type="text" class="form-control" value="@Model.CustomerName" readonly />
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-12">
                <label class="form-label">Người giao hàng</label>
                <select name="shipperID" class="form-select" required>
                    <option value="">-- Chọn người giao hàng --</option>
                    @if (ViewBag.Shippers != null)
                    {
                        foreach (var shipper in ViewBag.Shippers)
                        {
                            <option value="@shipper.ShipperID">@shipper.ShipperName</option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-bicycle"></i> Giao hàng
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>