@model SV22T1020330.Models.Sales.OrderViewInfo
@{
    ViewBag.Title = "Duyệt đơn hàng";
}

<div class="modal-header text-bg-info">
    <strong class="modal-title">
        Duyệt chấp nhận đơn hàng #@Model.OrderID
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form method="post" action="~/Order/Accept/@Model.OrderID">
    <div class="modal-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary()
            </div>
        }
        
        <div class="alert alert-info d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có chắc chắn muốn duyệt và chấp nhận đơn hàng này không?
        </div>
        
        <div class="row mb-3">
            <div class="col-md-4 fw-bold">Khách hàng:</div>
            <div class="col-md-8">@Model.CustomerName</div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-4 fw-bold">Ngày đặt:</div>
            <div class="col-md-8">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
