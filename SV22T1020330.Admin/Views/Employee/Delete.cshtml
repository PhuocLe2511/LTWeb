@model Employee
@{
    ViewBag.Title = "Xóa nhân viên";
}

@section PageToolBar {

    @if (ViewBag.CanDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger"
                onclick="return confirm('Bạn chắc chắn muốn xóa nhân viên này?')">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }

    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-person-x me-2"></i>
                    @(ViewBag.CanDelete ? "Xác nhận xóa nhân viên" : "Không thể xóa nhân viên")
                </h5>
            </div>

            <div class="card-body">

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                <form id="formDelete" method="post" asp-action="Delete" asp-route-id="@Model.EmployeeID">
                    @Html.AntiForgeryToken()

                    @if (ViewBag.CanDelete)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Bạn có chắc chắn muốn xóa nhân viên này không?
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Không thể xoá nhân viên này vì đang có dữ liệu liên quan.
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-2 text-start">
                            <img src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail mb-2"
                                 style="width: 100%;"
                                 alt="Ảnh nhân viên" />
                        </div>

                        <div class="col-md-10">
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Họ và tên</dt>
                                <dd class="col-sm-9">@Model.FullName</dd>

                                <dt class="col-sm-3">Ngày sinh</dt>
                                <dd class="col-sm-9">@Model.BirthDate?.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-3">Điện thoại</dt>
                                <dd class="col-sm-9">@Model.Phone</dd>

                                <dt class="col-sm-3">Email</dt>
                                <dd class="col-sm-9">@Model.Email</dd>

                                <dt class="col-sm-3">Địa chỉ</dt>
                                <dd class="col-sm-9">@Model.Address</dd>

                                <dt class="col-sm-3">Trạng thái</dt>
                                <dd class="col-sm-9">
                                    <span class="badge @(Model.IsWorking ? "bg-success" : "bg-secondary")">
                                        @(Model.IsWorking ? "Đang làm việc" : "Đã nghỉ")
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>