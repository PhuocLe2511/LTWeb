@model SV22T1020330.Models.Catalog.Category
@{
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>    
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-tags me-2"></i>
                    @ViewBag.Title
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Category/Save">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CategoryID" />

                    <div class="mb-3">
                        <label asp-for="CategoryName" class="form-label">Tên loại hàng</label>
                        <input asp-for="CategoryName" class="form-control" placeholder="Nhập tên loại hàng" autofocus />
                        <span asp-validation-for="CategoryName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả loại hàng"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
