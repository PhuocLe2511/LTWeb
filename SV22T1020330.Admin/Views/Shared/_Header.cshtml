@{
    var me = User.GetUserData();
    var displayName = me?.DisplayName;
    if (string.IsNullOrWhiteSpace(displayName))
        displayName = me?.Email ?? User.Identity?.Name ?? "Tài khoản";

    var photo = me?.Photo?.Trim();
    var hasPhoto = !string.IsNullOrEmpty(photo) && !string.Equals(photo, "nophoto.png", StringComparison.OrdinalIgnoreCase);
    var photoUrl = hasPhoto
        ? Url.Content($"~/images/employees/{photo}")
        : Url.Content("~/lib/adminlte/assets/img/user2-160x160.jpg");
}
<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>            
        </ul>        
        <ul class="navbar-nav ms-auto">            
            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    <img src="@photoUrl" class="user-image rounded-circle shadow" alt="@displayName" />
                    <span class="d-none d-md-inline">@displayName</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">                    
                    <li class="user-header text-bg-primary">
                        <img src="@photoUrl" class="rounded-circle shadow" alt="@displayName" />
                        <p>
                            @displayName
                            @if (me != null && !string.IsNullOrWhiteSpace(me.Email))
                            {
                                <small>@me.Email</small>
                            }
                        </p>
                    </li>                    
                    <li class="user-footer">
                        <a href="~/Account/ChangePassword" class="btn btn-default btn-flat">Đổi mật khẩu</a>
                        <a href="~/Account/Logout" class="btn btn-default btn-flat float-end">Thoát</a>
                    </li>                    
                </ul>
            </li>            
        </ul>        
    </div>
</nav>