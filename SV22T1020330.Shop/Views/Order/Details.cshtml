@model Tuple<SV22T1020330.Models.Sales.OrderViewInfo, List<SV22T1020330.Models.Sales.OrderDetailViewInfo>>
@using SV22T1020330.Models.Sales

<div class="shop-hero mb-4">
    <h1>Đơn hàng #@Model.Item1.OrderID</h1>
    <p class="mb-0">Chi tiết sản phẩm và trạng thái xử lý.</p>
</div>

<div class="shop-panel mb-4">
    <div class="row g-3 small">
        <div class="col-md-4">
            <span class="text-muted d-block">Thời gian đặt</span>
            <strong>@Model.Item1.OrderTime.ToString("dd/MM/yyyy HH:mm")</strong>
        </div>
        <div class="col-md-4">
            <span class="text-muted d-block">Trạng thái</span>
            @{
                var st = Model.Item1.Status;
                var css = st switch
                {
                    OrderStatusEnum.Rejected => "order-status-badge order-status-badge--rejected",
                    OrderStatusEnum.Cancelled => "order-status-badge order-status-badge--cancelled",
                    OrderStatusEnum.New => "order-status-badge order-status-badge--new",
                    OrderStatusEnum.Accepted => "order-status-badge order-status-badge--accepted",
                    OrderStatusEnum.Shipping => "order-status-badge order-status-badge--shipping",
                    OrderStatusEnum.Completed => "order-status-badge order-status-badge--completed",
                    _ => "order-status-badge order-status-badge--unknown"
                };
            }
            <span class="@css">@Model.Item1.Status.GetDescription()</span>
        </div>
        <div class="col-md-4">
            <span class="text-muted d-block">Tỉnh / Thành</span>
            <strong>@(Model.Item1.DeliveryProvince ?? "—")</strong>
        </div>
        <div class="col-12">
            <span class="text-muted d-block">Địa chỉ giao hàng</span>
            <strong>@(Model.Item1.DeliveryAddress ?? "—")</strong>
        </div>
    </div>
</div>

<div class="shop-panel p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Sản phẩm</th>
                    <th class="text-center">SL</th>
                    <th class="text-end">Đơn giá</th>
                    <th class="text-end pe-4">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Item2)
                {
                    <tr>
                        <td class="ps-4">@item.ProductName</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0") đ</td>
                        <td class="text-end pe-4 fw-semibold">@((item.Quantity * item.SalePrice).ToString("N0")) đ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">← Danh sách đơn hàng</a>
</div>
