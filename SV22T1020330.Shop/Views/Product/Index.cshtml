@model SV22T1020330.Models.Common.PagedResult<SV22T1020330.Models.Catalog.Product>
@{
    ViewData["Title"] = "Danh mục mặt hàng";
    var input = ViewBag.SearchInput as SV22T1020330.Models.Catalog.ProductSearchInput ?? new SV22T1020330.Models.Catalog.ProductSearchInput();
}

<h1 class="h3 mb-3">Danh mục mặt hàng</h1>

<form method="get" class="row g-2 mb-4 align-items-end" id="searchForm">
    <input type="hidden" name="Page" value="1" />
    <input type="hidden" name="PageSize" value="@input.PageSize" />
    <div class="col-md-3">
        <label class="form-label small mb-0">Loại hàng</label>
        <select name="CategoryID" class="form-select form-select-sm" asp-items="ViewBag.Categories"></select>
    </div>
    <div class="col-md-3">
        <label class="form-label small mb-0">Tên hàng</label>
        <input type="text" name="SearchValue" value="@input.SearchValue" class="form-control form-control-sm" placeholder="Tìm theo tên" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Giá từ</label>
        <input type="number" name="MinPrice" value="@(input.MinPrice == 0 ? "" : input.MinPrice.ToString(System.Globalization.CultureInfo.InvariantCulture))" class="form-control form-control-sm" min="0" step="0.01" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Đến</label>
        <input type="number" name="MaxPrice" value="@(input.MaxPrice == 0 ? "" : input.MaxPrice.ToString(System.Globalization.CultureInfo.InvariantCulture))" class="form-control form-control-sm" min="0" step="0.01" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary btn-sm w-100">Tìm kiếm</button>
    </div>
</form>

<!-- Container cho sản phẩm load qua AJAX -->
<div id="productContainer">
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
        <p class="mt-2 text-muted">Đang tải sản phẩm...</p>
    </div>
</div>

@section Scripts {
    <script>
        // Load sản phẩm qua AJAX
        function loadProducts() {
            // Hiển thị loading
            $("#productContainer").html(`
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Đang tải...</span>
                    </div>
                    <p class="mt-2 text-muted">Đang tải sản phẩm...</p>
                </div>
            `);
            
            var formData = $("#searchForm").serialize();
            
            $.get("@Url.Action("Search", "Product")", formData, function(data) {
                $("#productContainer").html(data);
            }).fail(function() {
                $("#productContainer").html('<div class="alert alert-danger">Lỗi tải sản phẩm. Vui lòng thử lại.</div>');
            });
        }

        // Pagination function với loading
        function paginationSearch(event, form, page) {
            event.preventDefault();
            $('input[name="Page"]', form).val(page);
            loadProducts();
        }

        // Load sản phẩm khi trang sẵn sàng
        $(document).ready(function() {
            loadProducts();
        });

        // Handle form submit
        $("#searchForm").submit(function(e) {
            e.preventDefault();
            loadProducts();
        });
    </script>
}
