@{
    ViewBag.Title = "Thông tin cá nhân";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="shop-panel">
            <h1 class="h4 fw-bold mb-3">
                <i class="bi bi-person-circle me-2"></i>Thông tin cá nhân
            </h1>
            <p class="text-muted small mb-4">Câp nhât thông tin tài khoân khách hàng.</p>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-info border-0 rounded-3 small">@ViewBag.Message</div>
            }

            <form asp-action="Profile" method="post">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Tên khách hàng</label>
                        <input name="customerName" type="text" class="form-control rounded-3" 
                               value="@ViewBag.CustomerName" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Tên liên hê</label>
                        <input name="contactName" type="text" class="form-control rounded-3" 
                               value="@ViewBag.ContactName" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted">Email</label>
                    <input type="email" class="form-control rounded-3" 
                           value="@ViewBag.Email" readonly />
                    <small class="text-muted">Email không thê thay dôi</small>
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted">Sô diên thoai</label>
                    <input name="phone" type="tel" class="form-control rounded-3" 
                           value="@ViewBag.Phone" />
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted">Dia chi</label>
                    <textarea name="address" class="form-control rounded-3" rows="2">@ViewBag.Address</textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted">Tinh/Thành phô</label>
                    <input name="province" type="text" class="form-control rounded-3" 
                           value="@ViewBag.Province" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill py-2 px-4 fw-semibold">
                        <i class="bi bi-save me-1"></i> Lûu thông tin
                    </button>
                    <a href="~/Product" class="btn btn-secondary rounded-pill py-2 px-4">
                        <i class="bi bi-arrow-left me-1"></i> Quay lai
                    </a>
                </div>
            </form>

            <div class="mt-4 pt-4 border-top">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1">Cài dât khác</h6>
                        <p class="text-muted small mb-0">Quân lý mât khâu và tài khoân</p>
                    </div>
                    <div class="btn-group" role="group">
                        <a href="~/Account/ChangePassword" class="btn btn-outline-primary btn-sm rounded-pill">
                            <i class="bi bi-key me-1"></i> Dôi mât khâu
                        </a>
                        <a href="~/Account/Logout" class="btn btn-outline-danger btn-sm rounded-pill">
                            <i class="bi bi-box-arrow-right me-1"></i> Dâng xuât
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
